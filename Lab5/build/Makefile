	$(MAKE) $(MAKESILENT) -f CMakeFiles/psmoveapi.dir/build.make CMakeFiles/psmoveapi.dir/src/psmove_time.c.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/psmoveapi_static.dir/build.make CMakeFiles/psmoveapi_static.dir/src/psmove_time.c.s
.PHONY : src/psmove_time.c.s

src/utils/psmovepair.o: src/utils/psmovepair.c.o
.PHONY : src/utils/psmovepair.o

